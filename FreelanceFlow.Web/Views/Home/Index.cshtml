@{
    ViewData["Title"] = "Ana Sayfa";
}

<section class="hero-section">
    <div class="container py-5">
        <h1 class="mb-3">Yazışmanı Yapıştır,<br />Belgelerini Al</h1>
        <p class="hero-subtitle mb-4">
            WhatsApp veya e-posta yazışmanızı yapıştırın, yapay zeka teklif, sözleşme ve faturanızı saniyeler içinde hazırlasın.
        </p>
        <a class="hero-cta" asp-action="Create" asp-controller="Document">Hemen Başla →</a>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <div class="text-center mb-4">
            <h2 class="fw-bold">Nasıl Çalışır?</h2>
        </div>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="card p-4 text-center fade-in-up">
                    <div class="step-number mx-auto mb-3">1</div>
                    <h5 class="fw-bold">Yazışmayı Yapıştır</h5>
                    <p class="text-muted mb-0">WhatsApp veya e-posta yazışmanızı kutucuğa yapıştırın</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card p-4 text-center fade-in-up">
                    <div class="step-number mx-auto mb-3">2</div>
                    <h5 class="fw-bold">AI Analiz Etsin</h5>
                    <p class="text-muted mb-0">Yapay zeka yazışmanızı analiz edip tüm bilgileri çıkarsın</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card p-4 text-center fade-in-up">
                    <div class="step-number mx-auto mb-3">3</div>
                    <h5 class="fw-bold">PDF İndir</h5>
                    <p class="text-muted mb-0">Profesyonel teklif, sözleşme ve faturanızı indirin</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <div class="text-center mb-4">
            <h2 class="fw-bold">Özellikler</h2>
        </div>
        <div class="row g-4">
            <div class="col-lg-3 col-md-6">
                <div class="card p-4 h-100 fade-in-up">
                    <div class="mb-3 fs-3">📋</div>
                    <h5 class="fw-bold">Teklif</h5>
                    <p class="text-muted mb-0">Proje kapsamı, fiyat ve süre detaylarını içeren profesyonel teklif.</p>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="card p-4 h-100 fade-in-up">
                    <div class="mb-3 fs-3">📝</div>
                    <h5 class="fw-bold">Sözleşme</h5>
                    <p class="text-muted mb-0">Yasal maddeler ve ödeme koşullarıyla resmi hizmet sözleşmesi.</p>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="card p-4 h-100 fade-in-up">
                    <div class="mb-3 fs-3">💰</div>
                    <h5 class="fw-bold">Fatura</h5>
                    <p class="text-muted mb-0">KDV dahil toplamlar, banka bilgileri ve ödeme tarihi ile fatura.</p>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="card p-4 h-100 fade-in-up">
                    <div class="mb-3 fs-3">✉️</div>
                    <h5 class="fw-bold">Takip E-postası</h5>
                    <p class="text-muted mb-0">Müşteriye anında gönderebileceğiniz hazır profesyonel metin.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <div class="row text-center g-4">
            <div class="col-md-4">
                <div class="stat-number">%85+</div>
                <div class="text-muted fw-semibold">Zaman Tasarrufu</div>
            </div>
            <div class="col-md-4">
                <div class="stat-number">4M+</div>
                <div class="text-muted fw-semibold">Potansiyel Kullanıcı</div>
            </div>
            <div class="col-md-4">
                <div class="stat-number">30sn</div>
                <div class="text-muted fw-semibold">İçinde Hazır</div>
            </div>
        </div>
    </div>
</section>
