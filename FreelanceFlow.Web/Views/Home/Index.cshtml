@{
    ViewData["Title"] = "Ana Sayfa";
}

<section class="hero-section">
    <div class="container text-center text-white">
        <h1 class="display-4 fw-bold mb-3">Yazışmanı Yapıştır, Belgelerini Al</h1>
        <p class="lead mx-auto mb-4 hero-subtitle">
            WhatsApp veya e-posta yazışmanızı yapıştırın, yapay zeka teklif, sözleşme ve faturanızı saniyeler içinde hazırlasın.
        </p>
        <a class="btn btn-accent btn-lg px-5 py-3" asp-controller="Document" asp-action="Create">Hemen Başla →</a>
    </div>
</section>

<section class="py-5 bg-white">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="fw-bold">Nasıl Çalışır?</h2>
        </div>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm p-4 text-center">
                    <div class="step-number mx-auto mb-3">1</div>
                    <div class="display-5 mb-3">📋</div>
                    <h5 class="fw-semibold">Yazışmayı Yapıştır</h5>
                    <p class="text-muted mb-0">WhatsApp veya e-posta yazışmanızı kutucuğa yapıştırın</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm p-4 text-center">
                    <div class="step-number mx-auto mb-3">2</div>
                    <div class="display-5 mb-3">🤖</div>
                    <h5 class="fw-semibold">AI Analiz Etsin</h5>
                    <p class="text-muted mb-0">Yapay zeka yazışmanızı analiz edip bilgileri çıkarsın</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm p-4 text-center">
                    <div class="step-number mx-auto mb-3">3</div>
                    <div class="display-5 mb-3">📄</div>
                    <h5 class="fw-semibold">PDF İndir</h5>
                    <p class="text-muted mb-0">Profesyonel teklif, sözleşme ve faturanızı indirin</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5 bg-light-blue">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="fw-bold">Ne Üretiyoruz?</h2>
        </div>
        <div class="row g-4">
            <div class="col-lg-3 col-md-6">
                <div class="card h-100 border-0 shadow-sm p-4">
                    <h5 class="fw-semibold mb-2">Teklif Dokümanı</h5>
                    <p class="text-muted mb-0">Proje kapsamı, fiyat ve teslimat süresini içeren profesyonel teklif</p>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="card h-100 border-0 shadow-sm p-4">
                    <h5 class="fw-semibold mb-2">Sözleşme</h5>
                    <p class="text-muted mb-0">Yasal maddeler, ödeme koşulları ve iptal şartlarını içeren sözleşme</p>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="card h-100 border-0 shadow-sm p-4">
                    <h5 class="fw-semibold mb-2">Fatura</h5>
                    <p class="text-muted mb-0">KDV dahil, banka bilgileri ve ödeme vadeli profesyonel fatura</p>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="card h-100 border-0 shadow-sm p-4">
                    <h5 class="fw-semibold mb-2">Takip E-postası</h5>
                    <p class="text-muted mb-0">Müşteriye göndermeye hazır profesyonel e-posta taslağı</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5 bg-white">
    <div class="container">
        <div class="row g-4 text-center">
            <div class="col-md-4">
                <div class="stat-number">%85+</div>
                <p class="fw-semibold mb-0">Zaman Tasarrufu</p>
            </div>
            <div class="col-md-4">
                <div class="stat-number">4M+</div>
                <p class="fw-semibold mb-0">Potansiyel Kullanıcı</p>
            </div>
            <div class="col-md-4">
                <div class="stat-number">30 Sn</div>
                <p class="fw-semibold mb-0">Saniyede Hazır</p>
            </div>
        </div>
    </div>
</section>
