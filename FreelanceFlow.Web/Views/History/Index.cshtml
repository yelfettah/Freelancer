@model List<FreelanceFlow.Core.Entities.Conversation>
@using FreelanceFlow.Core.Entities
@{
    ViewData["Title"] = "Geçmiş Belgelerim";
}

<section class="py-5">
    <div class="container">
        <h1 class="fw-bold mb-4">Geçmiş Belgelerim</h1>
        @if (TempData["HistoryError"] is string historyError && !string.IsNullOrWhiteSpace(historyError))
        {
            <div class="alert alert-warning">@historyError</div>
        }

        @if (Model is null || Model.Count == 0)
        {
            <div class="card border-0 shadow-sm p-5 text-center">
                <h4 class="fw-semibold mb-2">Henüz belge oluşturmadınız.</h4>
                <p class="text-muted mb-4">İlk konuşma analizinizi başlatıp teklif, sözleşme ve faturanızı oluşturabilirsiniz.</p>
                <div>
                    <a class="btn btn-accent" asp-controller="Document" asp-action="Create">İlk Belgenizi Oluşturun →</a>
                </div>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Tarih</th>
                            <th>Müşteri Adı</th>
                            <th>Sektör</th>
                            <th>Oluşturulan Belgeler</th>
                            <th class="text-end">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var conversation in Model)
                        {
                            var docTypes = conversation.Documents.Select(d => d.DocType).Distinct().ToList();
                            <tr>
                                <td>@conversation.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                                <td>@conversation.ClientName</td>
                                <td>@conversation.Sector</td>
                                <td>
                                    @if (docTypes.Contains(DocumentType.Proposal))
                                    {
                                        <span class="badge text-bg-primary me-1">Teklif</span>
                                        <a class="btn btn-sm btn-outline-primary ms-1" asp-action="Download" asp-controller="History" asp-route-conversationId="@conversation.Id" asp-route-type="Proposal">PDF</a>
                                    }
                                    @if (docTypes.Contains(DocumentType.Contract))
                                    {
                                        <span class="badge text-bg-success me-1">Sözleşme</span>
                                        <a class="btn btn-sm btn-outline-success ms-1" asp-action="Download" asp-controller="History" asp-route-conversationId="@conversation.Id" asp-route-type="Contract">PDF</a>
                                    }
                                    @if (docTypes.Contains(DocumentType.Invoice))
                                    {
                                        <span class="badge text-bg-warning">Fatura</span>
                                        <a class="btn btn-sm btn-outline-warning ms-1" asp-action="Download" asp-controller="History" asp-route-conversationId="@conversation.Id" asp-route-type="Invoice">PDF</a>
                                    }

                                    @if (conversation.Documents.Any(d => !string.IsNullOrWhiteSpace(d.JsonData)))
                                    {
                                        <details class="mt-2">
                                            <summary class="small text-muted">Yazı içeriğini göster</summary>
                                            @foreach (var doc in conversation.Documents.OrderBy(d => d.DocType))
                                            {
                                                <div class="mt-2">
                                                    <div class="fw-semibold small">@doc.DocType</div>
                                                    <pre class="small bg-light p-2 rounded border">@doc.JsonData</pre>
                                                </div>
                                            }
                                        </details>
                                    }
                                </td>
                                <td class="text-end">
                                    <form method="post" asp-action="Delete" asp-controller="History" class="d-inline"
                                          onsubmit="return confirm('Bu kaydı silmek istediğinize emin misiniz?');">
                                        <input type="hidden" name="id" value="@conversation.Id" />
                                        <button type="submit" class="btn btn-sm btn-danger">Sil</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</section>
