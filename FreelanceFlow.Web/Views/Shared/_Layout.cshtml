<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FreelanceFlow</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400&family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    @{
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
        var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
    }
    <header>
        <nav class="navbar navbar-expand-lg">
            <div class="container">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    FreelanceFlow <span class="logo-badge">AI</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Menü">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav ms-auto gap-lg-2">
                        <li class="nav-item">
                            <a class="nav-link @(currentController == "Dashboard" ? "active" : "")" asp-controller="Dashboard" asp-action="Index">Ana Sayfa</a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle @(currentController is "Document" or "Franchise" or "Lawyer" or "RealEstate" or "SME" ? "active" : "")" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">Modüller</a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" asp-controller="Document" asp-action="Create">Freelancer</a></li>
                                <li><a class="dropdown-item" asp-controller="Franchise" asp-action="Create">Franchise</a></li>
                                <li><a class="dropdown-item" asp-controller="Franchise" asp-action="Compare">Franchise Karşılaştır</a></li>
                                <li><a class="dropdown-item" asp-controller="Lawyer" asp-action="Create">Avukatlık</a></li>
                                <li><a class="dropdown-item" asp-controller="RealEstate" asp-action="Create">Emlak</a></li>
                                <li><a class="dropdown-item" asp-controller="RealEstate" asp-action="Compare">Emlak Karşılaştır</a></li>
                                <li><a class="dropdown-item" asp-controller="SME" asp-action="Create">KOBİ</a></li>
                            </ul>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(currentController == "History" ? "active" : "")" asp-controller="History" asp-action="Index">Geçmiş</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(currentController == "Profile" ? "active" : "")" asp-controller="Profile" asp-action="Index">⚙️ Profil</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    <footer class="footer">
        FreelanceFlow © 2026 | Hackathon Projesi
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
