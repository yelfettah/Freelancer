@model FreelanceFlow.Core.Models.GeneratedDocuments
@{
    ViewData["Title"] = "Sonuç";
}

@if (Model is null)
{
    <section class="py-5">
        <div class="container">
            <div class="alert alert-warning">Sonuç verisi bulunamadı. Lütfen tekrar deneyin.</div>
            <a class="btn-accent" asp-controller="Document" asp-action="Create">Belge Oluştur sayfasına dön</a>
        </div>
    </section>
    return;
}

<section class="py-5">
    <div class="container">
        <div class="result-header">
            <h2 class="fw-bold mb-2">Belgeleriniz Hazır! 🎉</h2>
            <p class="mb-2">Tüm belgeler başarıyla oluşturuldu.</p>
            <a class="download-all-btn" asp-action="DownloadAll">Tümünü İndir (ZIP)</a>
        </div>

        <div class="result-cards">
            <div class="card result-card">
                <div class="card-icon icon-proposal">📋</div>
                <h3>Teklif Dokümanı</h3>
                <div class="detail">@Model.Proposal.ProjectTitle</div>
                <div class="detail">@Model.Proposal.Price.ToString("N0") @Model.Proposal.Currency</div>
                <div class="detail">@Model.Proposal.Timeline</div>
                <a class="btn-outline download-btn" asp-action="DownloadProposal">PDF İndir</a>
            </div>

            <div class="card result-card">
                <div class="card-icon icon-contract">📝</div>
                <h3>Hizmet Sözleşmesi</h3>
                <div class="detail">@Model.Contract.FreelancerName ↔ @Model.Contract.ClientName</div>
                <div class="detail">@Model.Contract.StartDate - @Model.Contract.EndDate</div>
                <a class="btn-outline download-btn" asp-action="DownloadContract">PDF İndir</a>
            </div>

            <div class="card result-card">
                <div class="card-icon icon-invoice">💰</div>
                <h3>Fatura</h3>
                <div class="detail">@Model.Invoice.InvoiceNo</div>
                <div class="detail">Toplam: @Model.Invoice.Total.ToString("N0") @Model.Invoice.Currency (KDV Dahil)</div>
                <div class="detail">Son Ödeme: @Model.Invoice.DueDate</div>
                <a class="btn-outline download-btn" asp-action="DownloadInvoice">PDF İndir</a>
            </div>

            <div class="card result-card">
                <div class="card-icon icon-email">✉️</div>
                <h3>Takip E-postası</h3>
                <textarea class="form-control email-text" rows="6" readonly id="followUpEmailText">@Model.FollowUpEmail</textarea>
                <button class="btn-outline download-btn btn-copy" type="button" data-target="#followUpEmailText">Kopyala</button>
            </div>
        </div>

        <div class="savings-box">
            Tahmini Tasarruf: Haftada 4 saat → 30 dakika. %85+ zaman tasarrufu!
        </div>

        <div class="text-center mt-4">
            <a class="btn-accent" asp-action="Create">Yeni Yazışma Analiz Et</a>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        (() => {
            const copyBtn = document.querySelector('.btn-copy');
            if (!copyBtn) return;

            copyBtn.addEventListener('click', async () => {
                const selector = copyBtn.getAttribute('data-target');
                const textarea = selector ? document.querySelector(selector) : null;
                if (!textarea) return;

                const original = copyBtn.textContent;
                await navigator.clipboard.writeText(textarea.value || textarea.textContent || '');
                copyBtn.textContent = 'Kopyalandı ✓';
                setTimeout(() => {
                    copyBtn.textContent = original;
                }, 2000);
            });
        })();
    </script>
}
