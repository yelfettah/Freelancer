@using Microsoft.AspNetCore.Http
@{
    ViewData["Title"] = "Belge Oluştur";
    var profileJson = Context.Session.GetString("FreelancerProfile");
    decimal profileHourly = 0;
    if (!string.IsNullOrWhiteSpace(profileJson))
    {
        try
        {
            using var doc = System.Text.Json.JsonDocument.Parse(profileJson);
            if (doc.RootElement.TryGetProperty("HourlyRate", out var hourlyProperty))
            {
                profileHourly = hourlyProperty.GetDecimal();
            }
        }
        catch { }
    }
}

<div class="create-container">
    <div class="create-header">
        <h1>Belge Oluştur</h1>
        <p>Müşterinizle yaptığınız yazışmayı yapıştırın, yapay zeka teklif, sözleşme ve faturanızı hazırlasın.</p>
    </div>

    <div class="form-section">
        <div class="mb-4">
            <p>
                <a class="btn btn-outline-secondary btn-sm" data-bs-toggle="collapse" href="#profileCollapse" role="button" aria-expanded="false" aria-controls="profileCollapse">
                    Profil Bilgilerim
                </a>
            </p>
            <div class="collapse" id="profileCollapse">
                <div class="card card-body">
                    @if (!string.IsNullOrWhiteSpace(profileJson))
                    {
                        <span>Profil yüklendi ✓ (Saatlik: @profileHourly TL)</span>
                    }
                    else
                    {
                        <a asp-controller="Profile" asp-action="Index">Profil ayarlamak için tıklayın</a>
                    }
                </div>
            </div>
        </div>

        <form method="post" asp-action="Generate" asp-controller="Document" id="generateForm" data-loading-kind="document">
            <div class="form-group">
                <label>Yazışma</label>
                <div class="d-flex gap-2 mb-2">
                    <button type="button" class="btn btn-outline-secondary btn-sm chat-toggle active" id="rawToggle">Ham Metin</button>
                    <button type="button" class="btn btn-outline-secondary btn-sm chat-toggle" id="chatToggle">Chat Önizleme</button>
                </div>
                <textarea name="RawText" id="rawTextArea" class="form-control conversation-input" rows="10" required
                          placeholder="WhatsApp veya e-posta yazışmanızı buraya yapıştırın...

Örnek:
[10:15] Müşteri: Merhaba, web sitesi yaptırmak istiyoruz.
[10:16] Siz: Merhaba, tabii. Detayları konuşalım.
[10:18] Müşteri: E-ticaret sitesi, 150 ürün var.
[10:20] Siz: Anladım, fiyat ve süre için detayları konuşalım..."></textarea>
                <div id="chatPreview" class="chat-container d-none"></div>
                <div class="form-hint">WhatsApp'tan yazışmayı kopyalayıp doğrudan yapıştırabilirsiniz.</div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label>Adınız (Freelancer)</label>
                    <input type="text" name="FreelancerName" class="form-control" placeholder="Mehmet Yılmaz" required />
                </div>
                <div class="form-group">
                    <label>Müşteri Adı</label>
                    <input type="text" name="ClientName" class="form-control" placeholder="Ayşe Kaya" required />
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label>Sektör</label>
                    <select name="Sector" class="form-control">
                        <option value="Yazılım">Yazılım</option>
                        <option value="Tasarım">Tasarım</option>
                        <option value="Çeviri">Çeviri</option>
                        <option value="Danışmanlık">Danışmanlık</option>
                        <option value="Mimarlık">Mimarlık</option>
                        <option value="Fotoğraf/Video">Fotoğraf / Video</option>
                        <option value="Diğer">Diğer</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Para Birimi</label>
                    <select name="Currency" class="form-control">
                        <option value="TL">TL (Türk Lirası)</option>
                        <option value="USD">USD (Amerikan Doları)</option>
                        <option value="EUR">EUR (Euro)</option>
                    </select>
                </div>
            </div>

            <div class="form-group mt-3">
                <label>Özel Parametreler</label>
                <div id="parameterContainer">
                    <div class="row g-2 mb-2">
                        <div class="col-md-5"><input type="text" name="Parameters[0].Name" class="form-control parameter-name" placeholder="Acil iş ücreti fazlası" /></div>
                        <div class="col-md-5"><input type="text" name="Parameters[0].Value" class="form-control parameter-value" placeholder="%50" /></div>
                        <div class="col-md-2"><button type="button" class="btn btn-outline-danger w-100 remove-parameter">X</button></div>
                    </div>
                </div>
                <button type="button" id="addParameter" class="btn btn-outline-secondary btn-sm mt-2">Parametre Ekle +</button>
            </div>

            <div class="submit-section">
                <button type="submit" class="btn-accent">Belgeleri Oluştur 🚀</button>
                <div class="form-hint" style="margin-top:12px">Yapay zeka yazışmanızı analiz edecek, bu işlem 10-20 saniye sürebilir.</div>
            </div>
        </form>
    </div>
</div>

<div class="loading-overlay" id="loadingOverlay">
    <div class="loading-card">
        <div class="spinner"></div>
        <div class="loading-text" id="loadingText">Yazışma analiz ediliyor...</div>
        <div class="loading-subtext">Bu işlem birkaç saniye sürebilir</div>
    </div>
</div>

