@{
    ViewData["Title"] = "Belge Oluştur";
}

<div class="create-container">
    <div class="create-header">
        <h1>Belge Oluştur</h1>
        <p>Müşterinizle yaptığınız yazışmayı yapıştırın, yapay zeka teklif, sözleşme ve faturanızı hazırlasın.</p>
    </div>

    <div class="form-section">
        <form method="post" asp-action="Generate" asp-controller="Document" id="generateForm">
            <div class="form-group">
                <label>Yazışma</label>
                <textarea name="RawText" class="form-control conversation-input" rows="10" required
                          placeholder="WhatsApp veya e-posta yazışmanızı buraya yapıştırın...

Örnek:
[10:15] Müşteri: Merhaba, web sitesi yaptırmak istiyoruz.
[10:16] Siz: Merhaba, tabii. Detayları konuşalım.
[10:18] Müşteri: E-ticaret sitesi, 150 ürün var.
[10:20] Siz: Anladım, fiyat ve süre için detayları konuşalım..."></textarea>
                <div class="form-hint">WhatsApp'tan yazışmayı kopyalayıp doğrudan yapıştırabilirsiniz.</div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label>Adınız (Freelancer)</label>
                    <input type="text" name="FreelancerName" class="form-control" placeholder="Mehmet Yılmaz" required />
                </div>
                <div class="form-group">
                    <label>Müşteri Adı</label>
                    <input type="text" name="ClientName" class="form-control" placeholder="Ayşe Kaya" required />
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label>Sektör</label>
                    <select name="Sector" class="form-control">
                        <option value="Yazılım">Yazılım</option>
                        <option value="Tasarım">Tasarım</option>
                        <option value="Çeviri">Çeviri</option>
                        <option value="Danışmanlık">Danışmanlık</option>
                        <option value="Mimarlık">Mimarlık</option>
                        <option value="Fotoğraf/Video">Fotoğraf / Video</option>
                        <option value="Diğer">Diğer</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Para Birimi</label>
                    <select name="Currency" class="form-control">
                        <option value="TL">TL (Türk Lirası)</option>
                        <option value="USD">USD (Amerikan Doları)</option>
                        <option value="EUR">EUR (Euro)</option>
                    </select>
                </div>
            </div>

            <div class="submit-section">
                <button type="submit" class="btn-accent">Belgeleri Oluştur 🚀</button>
                <div class="form-hint" style="margin-top:12px">Yapay zeka yazışmanızı analiz edecek, bu işlem 10-20 saniye sürebilir.</div>
            </div>
        </form>
    </div>
</div>

<div class="loading-overlay" id="loadingOverlay">
    <div class="loading-card">
        <div class="spinner"></div>
        <div class="loading-text" id="loadingText">Yazışma analiz ediliyor...</div>
        <div class="loading-subtext">Bu işlem birkaç saniye sürebilir</div>
    </div>
</div>

@section Scripts {
    <script>
        (() => {
            window.__ffCreateScriptBound = true;
            const form = document.getElementById('generateForm');
            const overlay = document.getElementById('loadingOverlay');
            const loadingText = document.getElementById('loadingText');
            const steps = [
                "Yazışma analiz ediliyor...",
                "Teklif hazırlanıyor...",
                "Sözleşme oluşturuluyor...",
                "Fatura düzenleniyor...",
                "Son rötuşlar yapılıyor..."
            ];
            let current = 0;

            if (form && overlay && loadingText) {
                form.addEventListener('submit', () => {
                    overlay.classList.add('show');
                    setInterval(() => {
                        loadingText.style.opacity = '0';
                        setTimeout(() => {
                            current = (current + 1) % steps.length;
                            loadingText.textContent = steps[current];
                            loadingText.style.opacity = '1';
                        }, 180);
                    }, 3000);
                });
            }
        })();
    </script>
}
